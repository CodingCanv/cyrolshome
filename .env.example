# Supabase – crea un progetto su https://supabase.com e copia qui i valori
# Rinomina questo file in .env e compila le variabili

VITE_SUPABASE_URL= 
VITE_SUPABASE_ANON_KEY= 

# Opzionale: per le select "Assegnato a" / "Eseguito da" (UUID dei due utenti Auth)
# Dopo aver creato i due utenti in Supabase Auth, copia i loro UUID qui.
# VITE_USER_1_ID=
# VITE_USER_2_ID=
# VITE_USER_1_LABEL=Io
# VITE_USER_2_LABEL=Compagna
